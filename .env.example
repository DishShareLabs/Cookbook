# Network Port Configuration
PORT=3000

# Database Connection (MongoDB Atlas or Local Connection String)
# Example Atlas format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<db_name>
MONGODB_URI=your_mongodb_connection_string_here

# Cryptographic Security
# Provide a unique, random secret string to sign tokens and secure sessions.
JWT_SECRET=your_secure_jwt_secret_hash_token
